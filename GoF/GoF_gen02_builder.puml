title GoF - Creational #02 - Builder

class Product {
    +name
}

interface Builder {
    +build_part()
    +get_result(): Product
}

class ConcreteBuilder {
    +build_part()
    +get_result(): Product
}

Builder <|.. ConcreteBuilder
ConcreteBuilder ..> Product

class Director {
    -builder: Builder
    +construct()
}

Director --> Builder
@enduml